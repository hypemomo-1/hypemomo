# MONGODB_URI: MongoDB Atlas connection string for storing reviews.
MONGODB_URI="YOUR_MONGODB_ATLAS_URI_HERE"

# WHATSAPP_GROUP_NAME: Exact name of the WhatsApp group to send notifications to.
# Case-insensitive matching is used.
WHATSAPP_GROUP_NAME="Hype Momo Reviews"

# WHATSAPP_GROUP_ID: Direct WhatsApp group ID (e.g., "1234567890-1234567890@g.us").
# If set, this takes priority over WHATSAPP_GROUP_NAME.
# Leave empty "" to auto-detect from group name.
WHATSAPP_GROUP_ID=""
